<?xml version="1.0" encoding="UTF-8"?>
<ui>
    <panels>
        <panel id="mainFrame">
            <panelOptions
                focusable="false"
                doubleBuffered="true"
                cornerRadius="0"
                zIndex="0"
                background="#00000000">
                <visible/>
                <bounds x="0" y="0" width="900" height="520" />
            </panelOptions>

            <childComponents>
                <component
                    type="label"
                    style="title titleBold"
                    id="titleLabel"
                    localeKey="demo.title"
                    color="#ffffff"
                    fontSize="24"
                    accessibleName="KaylasUI Engine title">
                    <visible/>
                    <enabled/>
                    <bounds x="32" y="32" width="820" height="42" />
                    <properties>
                        <property name="demo.role" value="title" />
                    </properties>
                </component>

                <component
                    type="label"
                    style="title"
                    id="versionLabel"
                    localeKey="demo.version"
                    initialValue="version"
                    color="#ffffff"
                    fontSize="16">
                    <visible/>
                    <enabled/>
                    <bounds x="32" y="88" width="820" height="32" />
                </component>

                <component
                    type="label"
                    style="promptLabel"
                    id="statusLabel"
                    localeKey="demo.ready"
                    initialValue="java"
                    color="#ffffff"
                    fontSize="14">
                    <visible/>
                    <enabled/>
                    <bounds x="32" y="132" width="820" height="32" />
                </component>

                <component
                    type="fileSelector"
                    style="default"
                    id="directorySelectorRegression"
                    selectionMode="folder">
                    <enabled/>
                    <bounds x="32" y="164" width="360" height="42" />
                    <styles>
                        <style target="textField" name="textFieldMain" />
                        <style target="button" name="buttonMain" />
                    </styles>
                </component>

                <component
                    type="linkedStatusControl"
                    id="constructorRegression"
                    style="default">
                    <enabled/>
                    <bounds x="32" y="164" width="430" height="36" />
                </component>

                <component
                    type="compositeComponent"
                    style="default"
                    id="compositeDemo"
                    alignment="absolute"
                    initialValue="stable">
                    <visible/>
                    <enabled/>
                    <bounds x="32" y="184" width="820" height="280" />

                    <childComponents>
                        <component
                            type="label"
                            style="title"
                            id="compositeDemoTitle"
                            localeKey="demo.compositeTitle"
                            color="#ffffff"
                            fontSize="16">
                            <visible/>
                            <enabled/>
                            <bounds x="0" y="0" width="820" height="30" />
                        </component>

                        <component
                            type="label"
                            style="promptLabel"
                            id="compositeDemoState"
                            localeKey="demo.compositeState"
                            initialValue="interactive"
                            color="#ffffff"
                            fontSize="14">
                            <visible/>
                            <enabled/>
                            <bounds x="0" y="34" width="820" height="26" />
                        </component>

                        <component
                            type="button"
                            style="buttonMain compact"
                            id="taskManager"
                            localeKey="demo.openTaskManager"
                            cursor="hand"
                            accessibleName="Open task manager"
                            accessibleDescription="Opens the operating system task manager">
                            <visible/>
                            <enabled/>
                            <bounds x="0" y="74" width="180" height="42" />
                            <styleOverrides>
                                <property name="fontSize" value="13" />
                                <property name="fontStyle" value="bold" />
                            </styleOverrides>
                            <properties>
                                <property name="demo.role" value="primary-action" />
                                <property name="demo.priority" value="10" type="int" />
                            </properties>
                        </component>

                        <component
                            type="button"
                            style="altButton"
                            id="minimize"
                            localeKey="demo.minimizeWindow"
                            cursor="hand">
                            <visible/>
                            <enabled/>
                            <bounds x="198" y="74" width="180" height="42" />
                        </component>

                        <component
                            type="checkbox"
                            style="solid1"
                            id="demoToggle"
                            localeKey="demo.toggleFeature"
                            initialValue="true">
                            <visible/>
                            <enabled/>
                            <bounds x="0" y="132" width="240" height="32" />
                        </component>

                        <component
                            type="text-field"
                            style="textFieldMain"
                            id="demoInput"
                            localeKey="demo.inputPlaceholder"
                            initialValue="AURELIA online"
                            editable="true">
                            <visible/>
                            <enabled/>
                            <bounds x="260" y="126" width="260" height="44" />
                        </component>

                        <component
                            type="compositeSlider"
                            style="slidingOut"
                            id="demoSlider"
                            localeKey="demo.soundVolume"
                            fontSize="14"
                            initialValue="100"
                            minValue="50"
                            maxValue="100"
                            stepSize="6"
                            minorSpacing="5"
                            majorSpacing="10">
                            <visible/>
                            <enabled/>
                            <bounds x="0" y="184" width="430" height="72" />
                            <styles>
                                <style target="label" name="title" />
                                <style target="slider" name="slidingOut" />
                                <style target="spinner" name="textFieldMain" />
                            </styles>
                            <layoutConfig>
                                <label x="0" y="0" width="300" height="25" />
                                <slider x="0" y="26" width="300" height="45" />
                                <spinner x="320" y="20" width="90" height="34" />
                            </layoutConfig>
                        </component>
                    </childComponents>
                </component>
            </childComponents>

            <panels>
                <panel id="checkboxPanelRegressionA">
                    <panelOptions
                        focusable="false"
                        doubleBuffered="true"
                        cornerRadius="12"
                        zIndex="1"
                        background="#00000000">
                        <bounds x="910" y="0" width="220" height="48" />
                    </panelOptions>
                    <childComponents>
                        <component
                            type="checkbox"
                            style="solid1"
                            id="checkboxRegressionA"
                            localeKey="demo.toggleFeature"
                            initialValue="true">
                            <visible/>
                            <enabled/>
                            <bounds x="8" y="8" width="200" height="32" />
                        </component>
                    </childComponents>
                </panel>

                <panel id="checkboxPanelRegressionB">
                    <panelOptions
                        focusable="false"
                        doubleBuffered="true"
                        cornerRadius="12"
                        zIndex="2"
                        background="transparent">
                        <bounds x="910" y="60" width="220" height="48" />
                    </panelOptions>
                    <childComponents>
                        <component
                            type="checkbox"
                            style="solid1"
                            id="checkboxRegressionB"
                            localeKey="demo.toggleFeature"
                            initialValue="false">
                            <visible/>
                            <enabled/>
                            <bounds x="8" y="8" width="200" height="32" />
                        </component>
                    </childComponents>
                </panel>
            </panels>
        </panel>
    </panels>
</ui>
